{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(*)"
    ],
    "deny": [
      "Edit(*)",
      "Write(*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(sed:*)"
    ],
    "defaultMode": "plan"
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true
  }
}
{
  "enablePowerShellTool": true
}
