          <mxGeometry x="80" y="290" width="80" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="40" value="D2M Sequence:&#xa;1. Wait for trigger (d2m_exp_in rising)&#xa;2. X-ray: EWT-&gt;SCAN cycle (save to DDR)&#xa;3. X-ray resets: N x TRST/SRST/GRST cycles&#xa;4. Dark: EWT-&gt;SCAN cycle (calc subtraction)&#xa;5. Dark resets: N x TRST/SRST/GRST cycles&#xa;&#xa;od2m_xray=1 during xray_start/xray/xrayrst&#xa;od2m_dark=1 during dark_start/dark/darkrst&#xa;&#xa;Reset type selected by vio_xonflk_oe(1:0):&#xa;  0=TRST, 1=SRST, 2=GRST" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;align=left;spacingLeft=5;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
