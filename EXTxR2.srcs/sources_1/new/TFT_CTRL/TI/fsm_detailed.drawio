        <mxCell id="30" value="s_FINISH (5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="470" y="500" width="115" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="40" value="IDLE Conditions:&#xa;&#xa;D2M mode (d2m_en=1):&#xa;  - sm_idle + trigger -&gt; xray_start&#xa;  - xray/dark -&gt; EWT (scan)&#xa;  - xrayrst/darkrst -&gt; TRST/SRST/GRST&#xa;&#xa;Normal mode:&#xa;  - first_tft=1 -&gt; EWT or SCAN&#xa;  - grab_en=1, trig_mode=0:&#xa;      shutter=1 + ext_trig -&gt; EWT&#xa;      first_rst -&gt; TRST/SRST&#xa;      rolling -&gt; SCAN&#xa;  - grab_en=1, trig_mode=1/2:&#xa;      -&gt; EWT&#xa;  - No grab:&#xa;      ExtRst_MODE=00 -&gt; TRST/SRST&#xa;      ExtRst_MODE=01 -&gt; stay IDLE&#xa;      ExtRst_MODE=02 -&gt; timed TRST" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=8;align=left;spacingLeft=5;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="860" y="40" width="230" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="41" value="TRST: stft_cnt counts up&#xa;- D2M: if trigger detected and gate FWAIT -&gt; IDLE&#xa;- first_rst=0 and grab: wait gate FWAIT, set first_rst=1&#xa;- first_rst=1: rst_cnt++ until rst_num, then first_tft=1&#xa;- else: timeout on gate_rst_cycle" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=8;align=left;spacingLeft=5;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="860" y="310" width="250" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="42" value="EWT:&#xa;- req_align=1 or grab_en=0 -&gt; FINISH&#xa;- D2M xray: d2m_exp_in1=0 or timeout -&gt; SCAN&#xa;- D2M dark: stft_cnt &gt;= xexp_time -&gt; SCAN&#xa;- Ext2: ext_trig=0 or timeout -&gt; SCAN&#xa;- Normal: stft_cnt &gt;= sexp_time -&gt; SCAN&#xa;- ext_trig_out=1 during exposure" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=8;align=left;spacingLeft=5;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="860" y="400" width="250" height="100" as="geometry"/>
